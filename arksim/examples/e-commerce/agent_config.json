{
    "agent_type": "chat_completions",
    "agent_name": "e-commerce",
    "api_config": {
        "endpoint": "https://api.openai.com/v1/chat/completions",
        "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer ${OPENAI_API_KEY}"
        },
        "body": {
            "model": "gpt-5.1",
            "messages": [
                {
                    "role": "system",
                    "content": "You are a shopping assistant. \nPlease provide a complete answer to the user's question based on your knowledge. Response within 50 words."
                }
            ]
        }
    }
}